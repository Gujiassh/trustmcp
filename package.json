{
  "name": "trustmcp",
  "version": "0.1.0",
  "description": "CLI and GitHub Action for static security scanning of JavaScript/TypeScript Model Context Protocol (MCP) server repositories.",
  "type": "module",
  "bin": {
    "trustmcp": "dist/cli/main.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "bootstrap": "npm install && npm run build",
    "build": "tsc -p tsconfig.json",
    "pack:check": "npm run build && node scripts/pack-check.mjs",
    "pack:smoke": "npm run build && node scripts/pack-smoke.mjs",
    "publish:check": "npm test && npm run build && npm run pack:check",
    "test": "vitest run",
    "smoke": "npm run build && node scripts/smoke.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-security",
    "security",
    "audit",
    "security-scanner",
    "static-analysis",
    "cli",
    "github-action",
    "sarif",
    "code-scanning",
    "javascript",
    "typescript"
  ],
  "author": "ryanba",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gujiassh/trustmcp.git"
  },
  "homepage": "https://github.com/Gujiassh/trustmcp#readme",
  "bugs": {
    "url": "https://github.com/Gujiassh/trustmcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
